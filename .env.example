# =============================================================
# CRM Automação — Variáveis de Ambiente (Exemplo)
# -------------------------------------------------------------
# Copie este arquivo para .env na RAIZ do projeto:
#   cp .env.example .env
#
# Preencha com os valores reais e NUNCA versione o .env no Git.
# =============================================================

# ─────────────────────────────────────────────────────────────
# BACKEND — variáveis de runtime (lidas pelo Node.js)
# ─────────────────────────────────────────────────────────────

# Porta interna do container Node (padrão 3000, não alterar)
PORT=3000

# Chave secreta para assinar os tokens JWT de autenticação
# Use algo longo e aleatório (mínimo 32 caracteres)
JWT_SECRET=troque_por_uma_chave_forte_e_aleatoria

# Supabase — URL e chave do projeto
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=SEU_SERVICE_ROLE_KEY_AQUI

# Redis / Upstash (TLS obrigatório → prefixo rediss://)
REDIS_URL=rediss://default:SUA_SENHA@SEU_HOST.upstash.io:6379

# CORS — URL exata do frontend acessível pelo navegador
# Sem domínio: http://IP_DA_VPS:3100
# Com domínio:  https://crm.seudominio.com.br
FRONTEND_URL=http://IP_DA_VPS:3100

# ─────────────────────────────────────────────────────────────
# FRONTEND — usada como build arg pelo Dockerfile do Vite
# ─────────────────────────────────────────────────────────────
# ⚠️  Esta variável é embutida no bundle JavaScript durante o
#     'docker compose build'. Não use localhost aqui — ele seria
#     resolvido no navegador do usuário, não na VPS.
#
# Sem domínio: http://IP_DA_VPS:4100/api
# Com domínio:  https://api.seudominio.com.br/api
VITE_API_URL=http://IP_DA_VPS:4100/api
